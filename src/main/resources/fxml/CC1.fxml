               </children>
            </HBox>
            <Button fx:id="onShowIslandsButton" layoutX="14.0" layoutY="752.0" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#onShowIslandsButton" prefHeight="30.0" prefWidth="200.0" text="Show Islands" AnchorPane.bottomAnchor="5.0" AnchorPane.leftAnchor="5.0" />
            <Label alignment="CENTER" layoutX="525.0" layoutY="14.0" prefHeight="80.0" prefWidth="590.0" text="Character Card 1 Effect" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0" />
         </children>
      </AnchorPane>
   </children>
</VBox>
