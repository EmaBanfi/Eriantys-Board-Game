<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/11.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.polimi.ingsw.network.client.gui.controllers.CCG1Controller">
   <children>
      <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1200.0">
         <children>
            <Button fx:id="onSendButton" layoutX="1134.0" layoutY="752.0" mnemonicParsing="false" onAction="#onSendButton" prefHeight="30.0" prefWidth="200.0" text="Send" AnchorPane.bottomAnchor="5.0" AnchorPane.rightAnchor="5.0" />
            <HBox fx:id="hBoxStudent" layoutX="282.0" layoutY="281.0" prefHeight="25.0" prefWidth="596.0" spacing="50.0">
               <children>
                  <Label prefHeight="17.0" prefWidth="225.0" text="Which student do you want to move?" />
                  <ChoiceBox fx:id="studentsOnCard" prefHeight="25.0" prefWidth="157.0" />
                  <Button fx:id="onSelectButtonStudent" mnemonicParsing="false" onAction="#onSelectButtonStudent" prefHeight="25.0" prefWidth="48.0" text="Select" />
               </children>
            </HBox>
            <HBox fx:id="hBoxIsland" layoutX="243.0" layoutY="388.0" spacing="50.0" visible="false">
