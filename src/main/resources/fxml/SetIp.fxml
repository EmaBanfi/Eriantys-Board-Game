<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.polimi.ingsw.network.client.gui.controllers.SetIpController">
   <ImageView fitHeight="799.0" fitWidth="1200.0" pickOnBounds="true" preserveRatio="true" AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <Image url="@../images/background.jpg"/>
   </ImageView>

   <ImageView fitHeight="170.0" fitWidth="613.0" layoutX="322.0" layoutY="129.0" opacity="1" pickOnBounds="true"
              preserveRatio="true" AnchorPane.leftAnchor="312.5" AnchorPane.rightAnchor="312.5"
              AnchorPane.topAnchor="50.0">
      <Image url="@../images/eriantys_title.png"/>
   </ImageView>
   <Button defaultButton="true" layoutX="395.0" layoutY="365.0" maxHeight="-Infinity" maxWidth="-Infinity"
           minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#onPlayButton" prefHeight="30.0"
           prefWidth="200.0" text="Play" AnchorPane.bottomAnchor="5.0" AnchorPane.rightAnchor="5.0"/>
   <HBox alignment="CENTER_LEFT" layoutX="436.0" layoutY="385.0" spacing="20.0" AnchorPane.bottomAnchor="385.0"
         AnchorPane.leftAnchor="458.5" AnchorPane.rightAnchor="458.5" AnchorPane.topAnchor="385.0">
      <Label layoutX="436.0" layoutY="391.0" text="Insert the server ip:"/>
      <TextField fx:id="ipAddress" layoutX="520.0" layoutY="385.0" maxHeight="-Infinity" minHeight="-Infinity"
                 minWidth="-Infinity" prefHeight="30.0" prefWidth="160.0" promptText="ip address"
                 AnchorPane.bottomAnchor="385.0" AnchorPane.leftAnchor="520.0" AnchorPane.rightAnchor="520.0"
                 AnchorPane.topAnchor="385.0"/>
   </HBox>
</AnchorPane>
