<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="300.0" prefWidth="450.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.polimi.ingsw.network.client.gui.controllers.NotifyController">
   <children>
      <Label alignment="CENTER" layoutX="210.0" layoutY="30.0" prefHeight="80.0" prefWidth="590.0" text="Message from server" AnchorPane.leftAnchor="5.0" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0" />
      <Label fx:id="message" layoutX="210.0" layoutY="142.0" text="Label" />
      <Button fx:id="next" mnemonicParsing="false" onAction="#onNextButton" prefHeight="30.0" prefWidth="117.5" text="Next" AnchorPane.bottomAnchor="5.0" AnchorPane.rightAnchor="5.0" />
      <Button fx:id="close" layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#onCloseButton" prefHeight="30.0" prefWidth="117.5" text="Close" AnchorPane.bottomAnchor="5.0" AnchorPane.rightAnchor="5.0" />
   </children>
</AnchorPane>
