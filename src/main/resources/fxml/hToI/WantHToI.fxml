      <HBox layoutX="563.0" layoutY="391.0" spacing="20.0" AnchorPane.bottomAnchor="391.0" AnchorPane.leftAnchor="563.0" AnchorPane.rightAnchor="532.0" AnchorPane.topAnchor="391.0">
